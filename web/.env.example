# OAD Management UI — Environment Variables
# Copy this file to .env.local and fill in the values.

# Base URL of the OAD API server (no trailing slash)
VITE_API_BASE_URL=http://localhost:8080

# OIDC / OAuth 2.0 configuration (oidc-client-ts)
VITE_OIDC_AUTHORITY=http://localhost:8081/realms/oad
VITE_OIDC_CLIENT_ID=oad-web
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
VITE_OIDC_POST_LOGOUT_URI=http://localhost:5173/
VITE_OIDC_SCOPE=openid profile email
