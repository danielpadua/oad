        "text": "{\n  \"type_name\": \"user\",\n  \"allowed_properties\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"department\": { \"type\": \"string\" },\n      \"clearance_level\": { \"type\": \"integer\", \"minimum\": 1, \"maximum\": 5 },\n      \"email\": { \"type\": \"string\", \"format\": \"email\" },\n      \"active\": { \"type\": \"boolean\" }\n    },\n    \"required\": [\"department\"],\n    \"additionalProperties\": false\n  },\n  \"allowed_relations\": {\n    \"member_of\": { \"target_types\": [\"group\", \"role\"] },\n    \"manages\": { \"target_types\": [\"user\"] }\n  },\n  \"scope\": \"global\"\n}"
