        "mimeType": "application/json",
        "text": "{\n  \"entity_type_id\": \"{{ type_id }}\",\n  \"allowed_overlay_properties\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"credit.max_approval\": {\n        \"type\": \"number\",\n        \"minimum\": 0,\n        \"description\": \"Valor máximo de aprovação de crédito em BRL\"\n      },\n      \"credit.risk_score\": {\n        \"type\": \"string\",\n        \"enum\": [\"low\", \"medium\", \"high\", \"critical\"]\n      },\n      \"credit.credit_limit\": {\n        \"type\": \"number\",\n        \"minimum\": 0\n      },\n      \"credit.analyst_id\": {\n        \"type\": \"string\"\n      }\n    },\n    \"required\": [\"credit.risk_score\"],\n    \"additionalProperties\": false\n  }\n}"
      },
