    {
      "name": "Entity Types",
      "description": "CRUD entity_type_definition — FR-ETD-001..004\nExige role: admin",
      "item": [
        {
          "name": "List Entity Types",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/entity-types",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "entity-types"]
            },
            "description": "Retorna todos os entity types cadastrados ordenados por type_name."
          },
          "event": []
        },
        {
          "name": "Create Entity Type — user (global)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type_name\": \"user\",\n  \"allowed_properties\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"department\": { \"type\": \"string\" },\n      \"clearance_level\": { \"type\": \"integer\", \"minimum\": 1, \"maximum\": 5 },\n      \"email\": { \"type\": \"string\", \"format\": \"email\" },\n      \"active\": { \"type\": \"boolean\" }\n    },\n    \"required\": [\"department\"],\n    \"additionalProperties\": false\n  },\n  \"allowed_relations\": {\n    \"member_of\": { \"target_types\": [\"group\", \"role\"] },\n    \"manages\": { \"target_types\": [\"user\"] }\n  },\n  \"scope\": \"global\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/entity-types",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "entity-types"]
            },
            "description": "Cria o tipo 'user' com schema de propriedades e relações válidas.\nScope global: entidades desse tipo existem independentemente de sistema.\n\nApós criação: copie o campo 'id' da resposta para a variável type_id do ambiente."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    if (data && data.id) {",
                  "        pm.environment.set('type_id', data.id);",
                  "        console.log('[entity-type] type_id salvo:', data.id);",
                  "    }",
                  "}",
                  "pm.test('Entity type criado com sucesso', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Entity Type — role (global)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type_name\": \"role\",\n  \"allowed_properties\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"description\": { \"type\": \"string\" }\n    },\n    \"additionalProperties\": false\n  },\n  \"allowed_relations\": {\n    \"grants\": { \"target_types\": [\"permission\"] }\n  },\n  \"scope\": \"global\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/entity-types",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "entity-types"]
            },
            "description": "Cria o tipo 'role' para uso em RBAC."
          },
          "event": []
        },
        {
          "name": "Create Entity Type — 400 (invalid schema)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type_name\": \"broken_type\",\n  \"allowed_properties\": {\n    \"type\": \"not-a-valid-json-schema-type\"\n  },\n  \"allowed_relations\": {},\n  \"scope\": \"global\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/entity-types",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "entity-types"]
            },
            "description": "Deve retornar 400 VALIDATION_FAILED porque allowed_properties não é um JSON Schema válido."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Retorna 400 para schema inválido', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Entity Type",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/entity-types/{{type_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "entity-types", "{{type_id}}"]
            },
            "description": "Retorna um entity type pelo UUID.\nPré-requisito: variável type_id preenchida no ambiente."
          },
          "event": []
        },
        {
          "name": "Update Entity Type",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"allowed_properties\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"department\": { \"type\": \"string\" },\n      \"clearance_level\": { \"type\": \"integer\", \"minimum\": 1, \"maximum\": 5 },\n      \"email\": { \"type\": \"string\", \"format\": \"email\" },\n      \"active\": { \"type\": \"boolean\" },\n      \"cost_center\": { \"type\": \"string\" }\n    },\n    \"required\": [\"department\", \"email\"],\n    \"additionalProperties\": false\n  },\n  \"allowed_relations\": {\n    \"member_of\": { \"target_types\": [\"group\", \"role\"] },\n    \"manages\": { \"target_types\": [\"user\"] },\n    \"reports_to\": { \"target_types\": [\"user\"] }\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/entity-types/{{type_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "entity-types", "{{type_id}}"]
            },
            "description": "Substitui allowed_properties e allowed_relations de um entity type existente.\nTypename e Scope são imutáveis após criação.\nPré-requisito: variável type_id preenchida no ambiente."
          },
          "event": []
        },
        {
          "name": "Delete Entity Type",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/entity-types/{{type_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "entity-types", "{{type_id}}"]
            },
            "description": "Remove um entity type sem entidades associadas (FR-ETD-003).\nRetorna 400 BAD_REQUEST se existirem entidades do tipo.\nPré-requisito: variável type_id preenchida no ambiente."
          },
          "event": []
        }
      ]
    },
    {
