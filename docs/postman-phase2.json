    {
      "name": "Overlay Schemas",
      "description": "CRUD system_overlay_schema — FR-OVS-001..005\nExige role: admin\nDepende de: system_id e type_id preenchidos no ambiente",
      "item": [
        {
          "name": "List Overlay Schemas",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/systems/{{system_id}}/overlay-schemas",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "systems", "{{system_id}}", "overlay-schemas"]
            },
            "description": "Retorna todos os overlay schemas do sistema.\nPré-requisito: variável system_id preenchida no ambiente."
          },
          "event": []
        },
        {
          "name": "Create Overlay Schema",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_type_id\": \"{{type_id}}\",\n  \"allowed_overlay_properties\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"credit.max_approval\": {\n        \"type\": \"number\",\n        \"minimum\": 0,\n        \"description\": \"Valor máximo de aprovação de crédito em BRL\"\n      },\n      \"credit.risk_score\": {\n        \"type\": \"string\",\n        \"enum\": [\"low\", \"medium\", \"high\", \"critical\"]\n      },\n      \"credit.credit_limit\": {\n        \"type\": \"number\",\n        \"minimum\": 0\n      },\n      \"credit.analyst_id\": {\n        \"type\": \"string\"\n      }\n    },\n    \"required\": [\"credit.risk_score\"],\n    \"additionalProperties\": false\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/systems/{{system_id}}/overlay-schemas",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "systems", "{{system_id}}", "overlay-schemas"]
            },
            "description": "Cria o schema de overlay para o sistema 'credit' sobre o tipo 'user'.\nTodas as chaves em allowed_overlay_properties DEVEM ter prefixo 'credit.' (FR-OVS-005).\n\nPré-requisito: system_id e type_id preenchidos no ambiente.\nApós criação: copie o 'id' para a variável schema_id do ambiente."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    if (data && data.id) {",
                  "        pm.environment.set('schema_id', data.id);",
                  "        console.log('[overlay-schema] schema_id salvo:', data.id);",
                  "    }",
                  "}",
                  "pm.test('Overlay schema criado com sucesso', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Overlay Schema — 400 (namespace inválido)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_type_id\": \"{{type_id}}\",\n  \"allowed_overlay_properties\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"max_approval\": { \"type\": \"number\" },\n      \"credit.risk_score\": { \"type\": \"string\" }\n    }\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/systems/{{system_id}}/overlay-schemas",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "systems", "{{system_id}}", "overlay-schemas"]
            },
            "description": "Deve retornar 400 VALIDATION_FAILED: chave 'max_approval' não tem o prefixo 'credit.' obrigatório (FR-OVS-005).\nPré-requisito: system_id e type_id preenchidos no ambiente."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Retorna 400 para namespace inválido', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Overlay Schema — 409 (duplicado)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_type_id\": \"{{type_id}}\",\n  \"allowed_overlay_properties\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"credit.score\": { \"type\": \"number\" }\n    }\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/systems/{{system_id}}/overlay-schemas",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "systems", "{{system_id}}", "overlay-schemas"]
            },
            "description": "Deve retornar 409 CONFLICT: combinação (system_id, entity_type_id) já existe.\nPré-requisito: schema já criado para este par."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Retorna 409 para overlay duplicado', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Overlay Schema",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/systems/{{system_id}}/overlay-schemas/{{schema_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "systems", "{{system_id}}", "overlay-schemas", "{{schema_id}}"]
            },
            "description": "Retorna um overlay schema pelo UUID.\nPré-requisito: variáveis system_id e schema_id preenchidas no ambiente."
          },
          "event": []
        },
        {
          "name": "Update Overlay Schema",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"allowed_overlay_properties\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"credit.max_approval\": {\n        \"type\": \"number\",\n        \"minimum\": 0\n      },\n      \"credit.risk_score\": {\n        \"type\": \"string\",\n        \"enum\": [\"low\", \"medium\", \"high\", \"critical\"]\n      },\n      \"credit.credit_limit\": {\n        \"type\": \"number\",\n        \"minimum\": 0\n      },\n      \"credit.analyst_id\": {\n        \"type\": \"string\"\n      },\n      \"credit.approved_at\": {\n        \"type\": \"string\",\n        \"format\": \"date-time\"\n      }\n    },\n    \"required\": [\"credit.risk_score\"],\n    \"additionalProperties\": false\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/systems/{{system_id}}/overlay-schemas/{{schema_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "systems", "{{system_id}}", "overlay-schemas", "{{schema_id}}"]
            },
            "description": "Substitui allowed_overlay_properties de um overlay schema existente (FR-OVS-002).\nTodas as chaves continuam exigindo o prefixo do sistema.\nPré-requisito: variáveis system_id e schema_id preenchidas no ambiente."
          },
          "event": []
        },
        {
          "name": "Delete Overlay Schema",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{bearer_token}}", "type": "string" }]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/systems/{{system_id}}/overlay-schemas/{{schema_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "systems", "{{system_id}}", "overlay-schemas", "{{schema_id}}"]
            },
            "description": "Remove um overlay schema sem property overlays associados (FR-OVS-003).\nRetorna 400 se existirem property_overlays que dependem deste schema.\nPré-requisito: variáveis system_id e schema_id preenchidas no ambiente."
          },
          "event": []
        }
      ]
    }
  ]
}
