#!/usr/bin/env bash
# pre-commit: runs 'make pre-commit' on staged Go files.
# Blocks the commit if formatting or lint issues are found.
set -euo pipefail

# ── Collect staged Go files ───────────────────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [[ -z "$STAGED" ]]; then
  exit 0
fi

echo "[pre-commit] Checking Go code (make pre-commit)..."

if ! make pre-commit; then
  echo ""
  echo "[pre-commit] Commit aborted. Fix the issues above and try again."
  exit 1
fi

exit 0
