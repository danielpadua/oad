# =============================================================================
# Stage 1 — Builder
# Builds the Vite SPA. VITE_* build args are baked into the JS bundle.
# In the docker-compose stack the API is proxied by nginx, so
# VITE_API_BASE_URL is intentionally empty (relative paths).
# =============================================================================
FROM node:25-alpine AS builder

WORKDIR /app

COPY web/package*.json ./

RUN npm install

COPY web/ .

ARG VITE_API_BASE_URL=""
ARG VITE_OIDC_AUTHORITY=""
ARG VITE_OIDC_CLIENT_ID=""
ARG VITE_OIDC_REDIRECT_URI=""
ARG VITE_OIDC_POST_LOGOUT_URI=""
ARG VITE_OIDC_SCOPE="openid profile email"

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL \
    VITE_OIDC_AUTHORITY=$VITE_OIDC_AUTHORITY \
    VITE_OIDC_CLIENT_ID=$VITE_OIDC_CLIENT_ID \
    VITE_OIDC_REDIRECT_URI=$VITE_OIDC_REDIRECT_URI \
    VITE_OIDC_POST_LOGOUT_URI=$VITE_OIDC_POST_LOGOUT_URI \
    VITE_OIDC_SCOPE=$VITE_OIDC_SCOPE

RUN npm run build

# =============================================================================
# Stage 2 — Runtime (nginx)
# Serves the SPA and reverse-proxies /api and /health to the API container.
# =============================================================================
FROM nginx:stable-alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

CMD ["nginx", "-g", "daemon off;"]
